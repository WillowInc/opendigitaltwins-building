{
  "@id": "dtmi:com:willowinc:HeatingCoolingCoil;1",
  "@type": "Interface",
  "displayName": {
    "en": "Heating/Cooling Coil"
  },
  "description": {
    "en": "A single coil that can provide either heating or cooling to air. This includes reversible direct expansion (DX) coils found in heat pump equipment, where a reversing valve switches the coil between evaporator (cooling) and condenser (heating) duty, as well as hydronic two-pipe changeover coils supplied seasonally with chilled or hot water."
  },
