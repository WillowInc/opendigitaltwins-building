      "name": "regulatedBy",
      "target": "dtmi:com:willowinc:LeaseContract;1"
    },
        {
      "@type": "Relationship",
      "description": {
        "en": "The agent leasing out some leasable object, i.e., the owner of the asset."
      },
      "displayName": {
        "en": "lessor"
      },
      "name": "lessor",
      "target": "dtmi:com:willowinc:Agent;1"
    },
    {
      "@type": "Relationship",
      "description": {
        "en": "The agent leasing some leasable object, i.e., the user of the asset."
      },
      "displayName": {
        "en": "lessee"
      },
      "name": "lessee",
      "target": "dtmi:com:willowinc:Agent;1"
